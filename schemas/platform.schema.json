{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tabellio:schema:platform:v0.2",
  "title": "Tabellio Platform Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "remoteRepository", "git", "ledger", "validation", "reviews"],
  "properties": {
    "schemaVersion": { "const": "tabellio-platform/v0.2" },
    "remoteRepository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "remoteName", "publicSurface", "gitUrlEnv", "apiUrlEnv", "credentialFileEnv"],
      "properties": {
        "provider": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "remoteName": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "publicSurface": { "const": "git-only" },
        "gitUrlEnv": { "type": "string", "minLength": 1 },
        "apiUrlEnv": { "type": "string", "minLength": 1 },
        "credentialFileEnv": { "type": "string", "minLength": 1 }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stackManager", "codeRef", "controlRefs"],
      "properties": {
        "stackManager": { "const": "git-spice" },
        "codeRef": { "const": "refs/heads/main" },
        "controlRefs": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "enum": ["refs/tabellio/reviews", "refs/tabellio/validations", "refs/heads/entire/checkpoints/v1"] },
          "allOf": [
            { "contains": { "const": "refs/tabellio/reviews" } },
            { "contains": { "const": "refs/tabellio/validations" } },
            { "contains": { "const": "refs/heads/entire/checkpoints/v1" } }
          ]
        }
      }
    },
    "ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "checkpointRef"],
      "properties": {
        "provider": { "const": "entire" },
        "checkpointRef": { "const": "refs/heads/entire/checkpoints/v1" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "manifest", "resultRef"],
      "properties": {
        "runner": { "const": "tabellio-validate" },
        "manifest": { "type": "string", "minLength": 1 },
        "resultRef": { "const": "refs/tabellio/validations" }
      }
    },
    "reviews": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "stateRef"],
      "properties": {
        "provider": { "const": "tabellio" },
        "stateRef": { "const": "refs/tabellio/reviews" }
      }
    }
  }
}
